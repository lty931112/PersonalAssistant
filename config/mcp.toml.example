# MCP Server 配置示例
# 每个 server 可以是 stdio 或 http 类型（字段名与 pa-mcp McpServerConfig 一致：transport_type）

[[servers]]
name = "filesystem"
transport_type = "stdio"
command = "npx"
args = ["-y", "@anthropic/mcp-server-filesystem", "/tmp"]
enabled = true

[[servers]]
name = "web-search"
transport_type = "http"
url = "http://localhost:3001/mcp"
enabled = false

